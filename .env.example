# Required for chat, follow-ups, file analysis, model council, and OpenAI Realtime voice (proxied at /api/llm and POST /api/realtime/session in dev/preview — key stays server-side; the browser only receives short-lived client secrets from OpenAI).
OPENAI_API_KEY=

# Optional: OpenAI-compatible API base (OpenRouter, Azure, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Tavily web search (https://tavily.com)
VITE_TAVILY_API_KEY=
