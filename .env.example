# Required for chat, follow-ups, file analysis, model council, OpenAI Realtime voice, and image generation (proxied at /api/llm, POST /api/realtime/session, POST /api/images in dev/preview — key stays server-side; the browser never receives the API key).
OPENAI_API_KEY=

# Optional: OpenAI-compatible API base (OpenRouter, Azure, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Tavily web search (https://tavily.com)
VITE_TAVILY_API_KEY=
