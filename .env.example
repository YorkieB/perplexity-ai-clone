# Required for chat, follow-ups, file analysis, model council, and OpenAI TTS (proxied at /api/llm and /api/tts in dev/preview/Electron — key stays server-side).
OPENAI_API_KEY=

# Optional: client-side budgeting for the active chat model (provider still enforces hard limits).
# VITE_LLM_CONTEXT_WINDOW_TOKENS=40960
# VITE_LLM_MAX_COMPLETION_TOKENS=16384
# Comma-separated model ids to block if your inference catalog lists models you cannot call (404).
# VITE_BLOCKED_CHAT_MODEL_IDS=some-old-model-id,another-id
# Retries for provider rate limits (429) / transient errors — cannot remove provider quotas; increase attempts if needed.
# VITE_LLM_RATE_LIMIT_RETRIES=8

# Proxy-only: POST /api/llm rewrites unknown chat `model` ids for OpenAI routing (default allowlist + optional override).
# Comma-separated exact ids — when set, only these are forwarded; others become LLM_DEFAULT_CHAT_MODEL.
# LLM_ALLOWED_CHAT_MODELS=gpt-4o-mini,gpt-4o
# LLM_DEFAULT_CHAT_MODEL=gpt-4o-mini
# DigitalOcean inference route: optional allowlist and default slug when `model` is missing or invalid.
# LLM_ALLOWED_DO_CHAT_MODELS=openai-gpt-4o-mini,openai-gpt-5
# LLM_DEFAULT_DO_CHAT_MODEL=openai-gpt-4o-mini

# Optional: OpenAI-compatible API base (OpenRouter, Azure, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Voice: read-aloud uses OpenAI /api/tts first (no Microsoft). Browser speechSynthesis is only a fallback and skips Microsoft voices.
# TTS uses the same OPENAI_API_KEY as chat; DigitalOcean inference alone cannot drive /api/tts.
# A local MP3 file cannot be used to synthesize arbitrary text; clone voices require a provider API (e.g. ElevenLabs).
# Read-aloud defaults: gpt-4o-mini-tts + shimmer + British English instructions (see vite-end.d.ts).
# VITE_TTS_VOICE=shimmer
# VITE_TTS_MODEL=gpt-4o-mini-tts
# VITE_TTS_INSTRUCTIONS=-

# ElevenLabs TTS (Settings → API Keys can store key + voice id instead). Proxied at POST /api/tts with `provider: elevenlabs`.
# VITE_TTS_PROVIDER=elevenlabs
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# Optional: default model for ElevenLabs (see their API docs).
# ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# VITE_ELEVENLABS_VOICE_ID=
# VITE_ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Jarvis screen-agent / Python sidecar (behaviour logger; e.g. port 8765). Enables ElevenLabs TTS for that agent when 1.
# Omit or set to 1 for speech; set to 0 to keep screen-agent TTS off. Electron and Vite dev default this to 1 if unset.
JARVIS_VOICEAGENT_TTS=1

# Optional: absolute path (or path relative to cwd) to the Jarvis SQLite file (user facts, voice turns, learning).
# When unset, uses `data/jarvis.db` under the app root.
# Point the same path from both `npm run dev` (browser) and `npm run desktop` (Electron) so they share one DB.
# UI sync: `/api/ui-sync` mirrors whitelisted localStorage keys (threads, user-settings, workspaces, wake-word)
# into table `ui_local_snapshot` in this file — so tunnel + localhost see the same chat/settings without separate origins.
# If you override `JARVIS_DB_PATH` in one process but not the other, browser and desktop will diverge.
# JARVIS_DB_PATH=

# Jarvis Visual Engine — live `/api/vision/*` proxy (Electron + Vite dev) maps to `{base}/api/v1/*`.
# Face/emotion/motion and other vision features are implemented in the engine only; this app does not duplicate them.
# Start your engine on port 5000 or point `VISION_ENGINE_URL` at wherever it listens (no trailing slash).
# VISION_ENGINE_URL=http://127.0.0.1:5000
# JARVIS_VISION_ENGINE_URL=
# VISION_API_KEY=jarvis-vision-local
# In-repo engine: scene + clothing + mood use OpenAI vision — same `OPENAI_API_KEY` as the rest of Jarvis (loaded when Electron spawns Python).
# VISION_LLM_ENABLED=1
# VISION_LLM_MIN_INTERVAL_SEC=5
# VISION_OPENAI_MODEL=gpt-4o-mini
# Sharper, less generic room descriptions: VISION_OPENAI_IMAGE_DETAIL=high (default) or gpt-4o
# VISION_OPENAI_IMAGE_DETAIL=high
# Webcam: substring match on the OS device name. Default in app + proxy is **emeet** (eMeet webcams). Override for other cameras, e.g.:
# VISION_CAMERA_LABEL=Integrated Camera
# In-repo Python engine only: OpenCV device index if the wrong camera is selected (0–3). Optional:
# JARVIS_VISION_CAMERA_INDEX=1
# VITE_VISION_CAMERA_LABEL=Integrated Camera
#
# Auto-start the engine when Jarvis Electron opens (stopped on quit). Same command as in a terminal:
# JARVIS_VISION_ENGINE_COMMAND=python -m jarvis_visual_engine
# If `python` on PATH does not have the package, use the full interpreter that does:
# JARVIS_VISION_ENGINE_COMMAND=C:\path\to\venv\Scripts\python.exe -m jarvis_visual_engine
# Install the in-repo engine into your Python once: npm run setup:vision-engine
# Check: npm run verify:vision (must pass before Electron can auto-start the engine reliably).
# Electron then waits until GET {VISION_ENGINE_URL}/api/v1/context returns OK (cold start + eMeet). Timeout (optional, ms):
# JARVIS_VISION_ENGINE_READY_TIMEOUT_MS=60000
# For 24/7, run the engine via Task Scheduler / NSSM — do not rely on Electron alone.

# Web search — server-side key (recommended; stays out of the browser bundle).
# If set, the /api/search proxy uses Tavily for high-quality search results.
# Without a key, Jarvis falls back to DuckDuckGo (free, no sign-up, but less rich).
TAVILY_API_KEY=
# Legacy: client-side Tavily key (still works but exposed in the JS bundle — prefer TAVILY_API_KEY above).
# VITE_TAVILY_API_KEY=

# ─── DigitalOcean Gradient™ serverless inference (chat + model list) ───
# Use a Model Access / Inference API key (starts with sk-do-…). Same key for GET /v1/models and POST /v1/chat/completions.
# Not the same as a DigitalOcean “Personal Access Token” for api.digitalocean.com.
#
# Paste your key on the line below (no quotes), then save:
DIGITALOCEAN_API_KEY=
#
# Optional: same key exposed to the Vite client bundle only if you need it client-side (prefer DIGITALOCEAN_API_KEY above for dev/Electron proxy).
# VITE_DIGITALOCEAN_API_KEY=
#
# Uncomment after setting DIGITALOCEAN_API_KEY so the UI lists DO models without saving a key in Settings:
# VITE_USE_DO_INFERENCE=1

# Agent browser (Playwright MCP): optional port for scripts/agent-mcp-bridge.mjs and comma-separated host allowlist for navigate.
# AGENT_MCP_BRIDGE_PORT=3847
# AGENT_BROWSER_ALLOW_HOSTS=example.com,*.wikipedia.org

# Electron desktop only: auto-load an unpacked Chromium extension for the in-app browser (folder with manifest.json).
# ELECTRON_BROWSER_EXTENSION_PATH=

# Jarvis in-app browser (desktop): live web — default Bing search + homepage (do not point homepage at the app origin or the webview will load the UI inside itself).
# VITE_JARVIS_BROWSER_SEARCH_TEMPLATE=https://www.bing.com/search?q={query}
# VITE_JARVIS_BROWSER_SEARCH_NAME=Bing
# VITE_JARVIS_BROWSER_HOMEPAGE=https://www.bing.com/

# A2E (video.a2e.ai) — image/video/voice APIs via same-origin proxy /api/a2e/*
# Set VITE_ENABLE_A2E=1 to show A2E models in the selector and A2E Studio in the sidebar.
# The secret stays server-side: use A2E_API_KEY in .env (Vite + Electron load it for the proxy).
# VITE_ENABLE_A2E=1
# A2E_API_KEY=
# Optional: where "Live streaming" opens (default https://video.a2e.ai — A2E console).
# VITE_A2E_STREAMING_URL=https://video.a2e.ai
# Optional: JSON object merged into every A2E POST body (e.g. upstream flags from A2E’s API docs). Keys here override same-named fields from the app.
# VITE_A2E_POST_BODY_EXTRA={}

# Spotify embed (iframe) — https://developer.spotify.com/documentation/embeds
# Optional full iframe URL from Share → Embed (locks player; station list ignored).
# VITE_SPOTIFY_EMBED_URL=
# Default content when not picking a preset: type/id, open.spotify.com link, or spotify: URI.
# VITE_SPOTIFY_CONTENT=playlist/37i9dQZF1DXcBWIGoYBM5M
# Quick switches: "Label:playlist/id,Label2:https://open.spotify.com/track/..."
# VITE_SPOTIFY_PRESETS=Chill:playlist/37i9dQZF1DX4WYeuuaMeXt,Focus:playlist/37i9dQZF1DWZeKCadgRdKQ
#
# Spotify Web API (optional): create an app at https://developer.spotify.com/dashboard
# Add redirect URI: http://localhost:5173/oauth/callback (and your production URL). Use “Web” or “Desktop” app.
# In the app Settings → OAuth: enable PKCE. No Client Secret needed in the app — enter Client ID in Settings → OAuth → Spotify.

# TuneIn live radio — direct stream player (no embed; ad-free, no external links). Station id is the trailing s… in TuneIn URLs.
# VITE_TUNEIN_STATION_ID=s24939
# Presets shown as quick switches: "Label1:s111,Label2:s222"
# VITE_TUNEIN_PRESETS=BBC Radio 1:s24939,NPR News:s209772
# Station search uses same-origin /tunein-opml (Vite dev + preview proxy, Electron, vercel.json rewrite). Override only if you host elsewhere.
# VITE_TUNEIN_OPML_PROXY=

# NOW (UK streaming) — right-rail card has no NOW API; optional JSON replaces sample “continue watching” rows.
# VITE_NOWTV_HOME_URL=https://www.nowtv.com
# VITE_NOWTV_BOOKMARKS=[{"title":"The Last of Us","meta":"S2 · Ep3","progress":62,"href":"https://www.nowtv.com"}]

# Left rail: Social card — live X timeline + Threads post embeds (no API keys; uses Twitter widgets + Meta embed script).
# VITE_SOCIAL_X_SCREEN_NAME=BBCBreaking
# VITE_THREADS_POST_URLS=https://www.threads.net/@user/post/ABC123,https://www.threads.net/@user/post/DEF456

# Media Canvas — Image generation (gpt-image-1) and video generation (Sora) use the same OPENAI_API_KEY.
# No extra keys needed. Image editing uses gpt-image-1 via /api/images/edit.
# Video generation requires Sora API access on your OpenAI account.

# Suno API — music generation (get key from https://sunoapi.org)
# SUNO_API_KEY=

# Email (IMAP read + SMTP send) — proxied at POST /api/email/* in Electron and Vite dev. Credentials stay server-side.
# Primary account (default when tools omit account or use contact@…):
# EMAIL_1_ADDRESS=
# EMAIL_1_PASSWORD=
# Optional second mailbox (e.g. yorkie@…); tools pass account: full address to select it:
# EMAIL_2_ADDRESS=
# EMAIL_2_PASSWORD=
# Fasthost / Livemail defaults (override if your provider differs):
# EMAIL_IMAP_HOST=mail.livemail.co.uk
# EMAIL_IMAP_PORT=993
# EMAIL_SMTP_HOST=smtp.livemail.co.uk
# EMAIL_SMTP_PORT=465

# GitHub API — optional token for higher rate limits on code/repo search
# GITHUB_TOKEN=

# Plaid — bank account connection for financial advice (https://dashboard.plaid.com)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# PLAID_ACCESS_TOKEN= (set automatically after linking, or paste manually for testing)

# ═══════════════════════════════════════════════════════════════════════════════
# Jarvis + Vonage — Cloudflare Tunnel, dashboard URLs, and .env (Steps 5–8)
# ═══════════════════════════════════════════════════════════════════════════════
#
# Step 5 — Cloudflare Tunnel (two public hostnames)
# Option A — CLI (domain on Cloudflare DNS):
#   cloudflared tunnel login
#   cloudflared tunnel create jarvis-vonage
#   Put ~/.cloudflared/config.yml on Windows at: %USERPROFILE%\.cloudflared\config.yml
#   Example ingress (replace credentials-file with your <uuid>.json path):
#     tunnel: jarvis-vonage
#     credentials-file: C:/Users/YOU/.cloudflared/<tunnel-id>.json
#     ingress:
#       - hostname: voice.yourdomain.uk
#         service: http://localhost:3339
#       - hostname: jarvis.yourdomain.uk
#         service: http://localhost:5173
#       - service: http_status:404
#   cloudflared tunnel route dns jarvis-vonage voice.yourdomain.uk
#   cloudflared tunnel route dns jarvis-vonage jarvis.yourdomain.uk
#   cloudflared tunnel run jarvis-vonage
# Option B — Zero Trust dashboard: Networks → Tunnels → add connector + two public hostnames
#   voice.* → http://localhost:3339   |   jarvis.* → http://localhost:5173
# Cloudflare terminates TLS; Vonage uses wss://voice… and https://jarvis…
#
# Step 6 — Vonage dashboard (Voice app + your number) — paste exact URLs
# Example production (replace domain if yours differs):
# Voice — Answer URL (GET):   https://jarvis.yorkiebrown.uk/api/vonage/webhook/answer
# Voice — Event URL (POST):  https://jarvis.yorkiebrown.uk/api/vonage/webhook/event
# SMS — Inbound URL:           https://jarvis.yorkiebrown.uk/api/vonage/webhook/inbound-sms
#
# Step 7 — Fill .env below. Generate VONAGE_WS_SECRET, e.g. openssl rand -hex 24
#   or: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
#
# Step 8 — Run (keep tunnel + app up for public URLs):
#   (1) cloudflared tunnel run <your-tunnel-name>
#   (2) Web: npm run dev:tunnel   OR   Desktop + same Vite/5173 + bridge: npm run desktop:dev:tunnel
#       (desktop:dev:tunnel uses dev:tunnel so Cloudflare → 127.0.0.1:5173 matches vite allowedHosts)
# Vonage AI voice bridge auto-starts in Electron when VONAGE_AI_VOICE_BRIDGE_ENABLED=1. Health:
#   curl http://127.0.0.1:3339/health
# Expect JSON with ok, service vonage-ai-voice-bridge, version, streamingLlm, etc.
#
# ── Vonage SMS ──
# VONAGE_API_KEY=
# VONAGE_API_SECRET=
# Sender: E.164 digits without + (e.g. 447700900123) or approved alphanumeric (max 11 chars)
# VONAGE_FROM=

# ── Vonage Voice (outbound JWT calls) ──
# VONAGE_APPLICATION_ID=
# VONAGE_PRIVATE_KEY=   (or use VONAGE_PRIVATE_KEY_BASE64= for PEM as one line)

# ── Vonage AI voice bridge (WebSocket media: STT → LLM → TTS) ──
# Public wss URL must reach the tunnel on port 3339; ?token= must match VONAGE_WS_SECRET if set.
# VONAGE_PUBLIC_WS_URL=wss://voice.yorkiebrown.uk/voice/ws
# VONAGE_WS_SECRET=
# VONAGE_AI_VOICE_BRIDGE_ENABLED=1
# VONAGE_AI_VOICE_PORT=3339
# VONAGE_AI_MAX_TURNS=30
# VONAGE_AI_VOICE_POLL_MS=4500
# Tier 4: stream LLM → sentence TTS (default on; 0 = batch chat + Tier 3 TTS only)
# VONAGE_AI_STREAMING_LLM=1

# Deepgram streaming STT (Tier 2 bridge; optional — Whisper batch if unset)
# DEEPGRAM_API_KEY=
# DEEPGRAM_MODEL=nova-2
# DEEPGRAM_ENDPOINTING_MS=400

# ElevenLabs TTS on bridge (Tier 3; also set ELEVENLABS_* at top of file)
# VONAGE_ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# Tier 5 — signed inbound webhooks (Dashboard → Settings → API Settings → Signature secret)
# VONAGE_SIGNATURE_SECRET=

# Jarvis on the phone line
# VONAGE_AI_SYSTEM_PROMPT=
# VONAGE_AI_USER_NAME=
# JARVIS_USER_NAME=

# OpenAI TTS fallback when ElevenLabs off on bridge: alloy, echo, fable, onyx, nova, shimmer
# VONAGE_AI_OPENAI_VOICE=alloy

# Local event store (voice + inbound SMS). Default: .vonage-events/ under project root
# VONAGE_EVENT_STORE_DIR=

# X (Twitter) — API keys for posting (free tier: write-only, 1,500 tweets/month)
# Get keys at https://developer.twitter.com/en/portal/dashboard
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# DigitalOcean Managed PostgreSQL — full connection string (pgvector RAG store).
# DATABASE_URL=postgresql://user:pass@host:25060/defaultdb?sslmode=require
# If the DB is unreachable (ETIMEDOUT / "Connection terminated due to connection timeout"), RAG schema init is skipped and the knowledge base is disabled until fixed.
# To silence errors and run without PostgreSQL/RAG locally: RAG_DB_ENABLED=false
# RAG_DB_ENABLED=true

# DigitalOcean Spaces — S3-compatible storage (RAG document files + behaviour logging).
# Use one set: `DO_SPACES_*` below (recommended) or legacy `SPACES_*` (SPACES_ENDPOINT, SPACES_BUCKET, SPACES_ACCESS_KEY, SPACES_SECRET_KEY, SPACES_REGION).
# Regional endpoint only — e.g. https://nyc3.digitaloceanspaces.com (not the bucket subdomain URL).
DO_SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
# Bucket name ONLY (no slash, no subfolder). Wrong: jarvis-knowledge-documents/anything
DO_SPACES_BUCKET=jarvis-knowledge-documents
DO_SPACES_KEY=your_spaces_access_key
DO_SPACES_SECRET=your_spaces_secret_key
DO_SPACES_REGION=nyc3

# Screen agent — Python WebSocket sidecar (must match src/agents/screen-agent/config DEFAULT_CONFIG.wsPort)
# Launcher sets SCREEN_AGENT_WS_PORT for Python; keep SCREEN_AGENT_PORT in sync for the TS ScreenAgent.
SCREEN_AGENT_PORT=8765
SCREEN_AGENT_TRANSPORT=websocket
SCREEN_AGENT_PATH=python/screen_agent.py
# Seconds between periodic screen_change heartbeats (0 = off). First frame always emits so Jarvis gets an initial view.
SCREEN_AGENT_HEARTBEAT_SEC=30
# Default 0: main-process ElevenLabs for jarvis:speak overlaps Voice Mode. Set 1 only for screen-agent TTS without Voice Mode.
JARVIS_VOICEAGENT_TTS=0
# Interpreter that has python/requirements.txt installed (Windows: often conda or py launcher)
# SCREEN_AGENT_PYTHON=C:\Users\YOU\miniconda3\python.exe
# Windows default install path for Tesseract (pytesseract); set if `tesseract` is not on PATH
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
